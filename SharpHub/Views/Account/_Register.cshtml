@model UserRegisterViewModel

<div class="container p-4" style="max-width: 400px;">
    <div class="d-flex justify-content-center mb-4">
        <div class="nav nav-tabs w-100">
            <div data-target="Login" class="nav-link login-tab w-50 text-center">Login</div>
            <div data-target="Register" class="nav-link active login-tab w-50 text-center">Register</div>
        </div>
    </div>
    <form asp-action="Register" asp-controller="Account" method="post"
          class="d-flex flex-column justify-content-between" style="min-height: 350px;">
        <div>
            <div class="mb-3">
                <label asp-for="Username" class="form-label">Username</label>
                <input asp-for="Username" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" class="form-control" type="password" />
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">Retype password</label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" />
            </div>
        </div>
        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger">
                @if (ViewData.ModelState["Username"]?.Errors.Count > 0)
                {
                    <p><span asp-validation-for="Username"></span></p>
                }
                @if (ViewData.ModelState["Password"]?.Errors.Count > 0)
                {
                    <p><span asp-validation-for="Password"></span></p>
                }
                @if (ViewData.ModelState["ConfirmPassword"]?.Errors.Count > 0)
                {
                    <p><span asp-validation-for="ConfirmPassword"></span></p>
                }
            </div>
        }
        <button type="submit" class="btn btn-primary w-100 mt-3">Register</button>
    </form>
</div>
