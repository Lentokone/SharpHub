@{
    ViewData["Title"] = "Not Found";
}

<div class="container mt-5">
    <div class="text-center py-5">

        <h1 class="display-4 text-muted">404</h1>
        <h2 class="h4 mb-3">The page you are looking for could not be found.</h2>

        <p class="text-secondary mb-4">
            It may have been moved, deleted, or you might not have permission to view it.
        </p>

        <a href="/" class="btn btn-primary">
            Return to Home
        </a>

    </div>
</div>

<style>
    .container {
        max-width: 700px;
    }
</style>
