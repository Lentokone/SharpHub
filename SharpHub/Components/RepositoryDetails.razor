@using MongoDB.Bson
@using SharpHub.Models
@using SharpHub.Models.Services

@inject NavigationManager Nav

<div class="container mt-4">

@if (ModalState)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);" @onclick="OnBackdropClick">
            <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
                <div class="modal-content shadow-lg">
                    <div class="modal-header">
                        <h5 class="modal-title">Delete Repository</h5>
                        <button type="button" class="btn-close" aria-label="Close" @onclick="HideModal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <span class="fw-semibold">Are you sure you want to delete @Model.CurrentRepository.RepositoryName ?</span>
                        </div>
                        <div class="d-flex justify-content-end mt-3">
                            <button class="btn btn-primary" @onclick="HandleDeletion" >Yes</button>
                            <button class="btn btn-outline-secondary ms-2" @onclick="HideModal">Cancel</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    <div class="mb-4">
        <h1 class="fw-bold">@Model.CurrentRepository.RepositoryName</h1>
        <p class="text-muted">@Model.CurrentRepository.Description</p>
    </div>
    <div class="card mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Clone or download as zip, this repository Tai vaikka delete</span>
        </div>
    </div>
    <div class="card mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Unohdin jo mikä tämäkin oli</span>
            <button class="btn btn-sm btn-primary" @onclick="() => ShowModal()">Delete</button>
        </div>
    </div>
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header fw-semibold">
                    Repository Tree
                </div>
                <div class="card-body">
                    <p class="text-muted">[ File tree placeholder ]</p>
                </div>
            </div>
        </div>
        <div class="col-md-8 mb-4">
            <div class="card h-100">
                <div class="card-header fw-semibold">
                    README.md
                </div>
                <div class="card-body">
                    <p class="text-muted">[ README content placeholder ]</p>
                    <Markdown style="max-height: 437px;overflow-y:auto;">@markdown</Markdown>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public required RepositoryDetailsViewModel Model { get; set; }

<!-- This is only for testing.
     It will fetch the repository README properly
-->
    private string markdown = "# Heading 1\n## Heading 2\n\n![BlazorBootstrap](https://demos.blazorbootstrap.com/images/logo/logo-color.svg =50)";

    private bool ModalState;
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            StateHasChanged();
        }
    }

    private void ShowModal()
    {
        ModalState = true;
    }

    private void HideModal()
    {
        ModalState = false;
    }

    private void OnBackdropClick()
    {
        HideModal();
    }
    private void HandleDeletion()
    {
        Model.CurrentRepository._id = ObjectId.Parse(Model.ObjectId);

        Model.CurrentRepository.IsDeleted = true;
        MongoManipulator.Save(Model.CurrentRepository);

        Console.WriteLine("HandleDeletion() called");
        Nav.NavigateTo("/RepositoryManager", forceLoad: true);
        HideModal();
        StateHasChanged();
    }
}
