@using SharpHub.Models


<div class="container mt-4">

    <!-- Repo Header -->
    <div class="mb-4">
        <h1 class="fw-bold">@Model.RepositoryName</h1>
        <p class="text-muted">Repository description goes here…</p>
    </div>

    <!-- Clone Section -->
    <div class="card mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Clone this repository</span>
        </div>
    </div>
    <div class="card mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">
            <span class="fw-semibold">@testi</span>
        </div>
    </div>

    <div class="row">

        <!-- Tree Sidebar -->
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header fw-semibold">
                    Repository Tree
                </div>
                <div class="card-body">
                    <p class="text-muted">[ File tree placeholder ]</p>
                </div>
            </div>
        </div>

        <!-- README Renderer -->
        <div class="col-md-8 mb-4">
            <div class="card h-100">
                <div class="card-header fw-semibold">
                    README.md
                </div>
                <div class="card-body">
                    <p class="text-muted">[ README content placeholder ]</p>
                </div>
            </div>
        </div>

    </div>
</div>


@code {
    [Parameter]
    public RepositoryDetailsViewModel Model { get; set; }


    string testi = "Testimuuttuja";

    int ttester = 0;
    // TOIMIII!!!!!!!!!!!!!
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            testi = "Tästä sitten se oikea load juttu? Mikä load juttu? Siis repository data ja muut.";
            StateHasChanged();
        }
    }
}