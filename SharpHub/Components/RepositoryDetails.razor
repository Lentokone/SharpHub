@using LibGit2Sharp
@using SharpHub.Models
@using SharpHub.Models.Services

@inject NavigationManager Nav

<div class="container mt-4">

    @if (ModalState)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);"
             @onclick="OnBackdropClick">
            <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
                <div class="modal-content shadow-lg">
                    <div class="modal-header">
                        <h5 class="modal-title">Delete Repository</h5>
                        <button type="button" class="btn-close" aria-label="Close" @onclick="HideModal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <span class="fw-semibold">Are you sure you want to delete
                                @Model.CurrentRepository.RepositoryName ?</span>
                            </div>
                            <div class="d-flex justify-content-end mt-3">
                                <button class="btn btn-primary" @onclick="HandleDeletion">Yes</button>
                                <button class="btn btn-outline-secondary ms-2" @onclick="HideModal">Cancel</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        <div class="container">
            <div class="mb-4">
                <h1 class="fw-bold">
                    @Model.CurrentRepository.RepositoryName
                </h1>
                <div class="text-body">
                    @Model.CurrentRepository.Description
                </div>
            </div>
            <div class="row mb-4">
                <div class="col-md-8">
                    <div class="card h-100">
                        <div class="card-header fw-semibold">
                            Repository Tree
                        </div>
                        <div class="card-body">
                            <div class="text-muted">
                                [ File tree placeholder ]
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-header fw-semibold">
                            Repository Actions
                        </div>
                        <div class="card-body d-grid gap-2">
                            <button class="btn btn-outline-primary">
                                Clone Repository
                            </button>
                            <button class="btn btn-outline-secondary">
                                Download ZIP
                            </button>
                            <button class="btn btn-danger" @onclick="ShowModal">
                                Delete Repository
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card">
                <div class="card-header fw-semibold">
                    README.md
                </div>
                <div class="card-body">
                    <Markdown style="max-height: 437px; overflow-y:auto;">
                        @markdown
                    </Markdown>
                </div>
            </div>
        </div>
    </div>
@code {
    [Parameter]
    public required RepositoryDetailsViewModel Model { get; set; }
    private string markdown = "# No Readme file found";

    private bool ModalState;
    protected override void OnParametersSet()
    {
        var repoPath = Model.CurrentRepository.RepositoryPath;
        var readmeContent = GetReadme();

        if (readmeContent.Length != 0)
            markdown = GetReadme();
    }

    private void ShowModal()
    {
        ModalState = true;
    }

    private void HideModal()
    {
        ModalState = false;
    }

    private void OnBackdropClick()
    {
        HideModal();
    }

    private void HandleDeletion()
    {
        Model.CurrentRepository._id = MongoDB.Bson.ObjectId.Parse(Model.ObjectId);

        Model.CurrentRepository.IsDeleted = true;
        MongoManipulator.Save(Model.CurrentRepository);

        Console.WriteLine("HandleDeletion() called");
        Nav.NavigateTo("/RepositoryManager", forceLoad: true);
        HideModal();
        StateHasChanged();
    }

    private string GetReadme()
    {
        var repo = new LibGit2Sharp.Repository(Model.CurrentRepository.RepositoryPath);
        var readmePath = Path.Combine(Model.CurrentRepository.RepositoryPath, "readme.md");
        var commit = repo.Head.Tip;
        if (commit == null)
            return string.Empty;

        var names = new[]
        {
            "README.md",
            "readme.md",
            "README"
        };
        foreach (var name in names)
        {
            var entry = commit[name];

            if (entry?.Target is Blob blob)
                return blob.GetContentText();
        }
        return string.Empty;
    }
}
