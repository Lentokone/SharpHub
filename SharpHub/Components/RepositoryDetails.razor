    <!-- Repo Header -->
    <div class="mb-4">
        <h1 class="fw-bold">@Model.RepositoryName</h1>
        <p class="text-muted">Repository description goes here…</p>
    </div>

    <!-- Clone Section -->
    <div class="card mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Clone this repository</span>
        </div>
    </div>
    <div class="card mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">
            <span class="fw-semibold">@testi</span>
        </div>
    </div>

    <div class="row">

        <!-- Tree Sidebar -->
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header fw-semibold">
                    Repository Tree
                </div>
                <div class="card-body">
                    <p class="text-muted">[ File tree placeholder ]</p>
                </div>
            </div>
        </div>

        <!-- README Renderer -->
        <div class="col-md-8 mb-4">
            <div class="card h-100">
                <div class="card-header fw-semibold">
                    README.md
                </div>
                <div class="card-body">
                    <p class="text-muted">[ README content placeholder ]</p>
                    <Markdown style="max-height: 437px;overflow-y:auto;">@markdown</Markdown>
                </div>
            </div>
        </div>

    </div>
</div>
