<h3>blazortest</h3>
<p>The time is @DateTime.Now.ToLongTimeString()</p>

<p role="status">current count: @currentCount</p>
<button class="btn btn-primary" @onclick="IncrementCount">monkey</button>
@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
        Console.WriteLine("Button clicked, currentCount is now: " + currentCount);
    }
}