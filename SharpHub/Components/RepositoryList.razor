@using SharpHub.Models
@using SharpHub.Models.Services
@using System.Security.Claims

<h3>RepositoryList</h3>
<p>@Model.UserName</p>
@if (Model.Repositories.Count == 0)
{
    <p>No repositories found.</p>
    <p>SAATANA</p>
    <p>SAATANA</p>
    <p>SAATANA</p>
}
@if (repositories.Count == 0)
{
    <p>No repositories found.</p>
    @foreach (var repo in repositories)
    {
        <li>@repo.RepositoryName - @repo.Description</li>
        <li> Updated on @repo.EditedAt</li>
    }
}
else
{
    <ul>
        @foreach (var repo in repositories)
        {
            <li>@repo.RepositoryName - @repo.Description</li>
            <li> Updated on @repo.EditedAt</li>
        }
    </ul>
}




