@using SharpHub.Models
@using SharpHub.Models.Services
@using System.Security.Claims

@if (!Model.Repositories.Any())
{
    <div class="text-center p-4">
        <p class="text-muted">No repositories found.</p>
    </div>
}
else
{
    @if (ModalState)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);" @onclick="OnBackdropClick">
            <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
                <div class="modal-content shadow-lg">

                    <div class="modal-header">
                        <h5 class="modal-title">Create Repository</h5>
                        <button type="button" class="btn-close" aria-label="Close" @onclick="HideModal"></button>
                    </div>

                    <div class="modal-body">
                        <EditForm Model="@newRepo" OnValidSubmit="HandleValidSubmit">
                            <DataAnnotationsValidator />
                            <div class="mb-3">
                                <label for="RepositoryName" class="form-label">Repository Name</label>
                                <InputText id="RepositoryName" class="form-control" @bind-Value="newRepo.RepositoryName" />
                                <ValidationMessage For="@(() => newRepo.RepositoryName)" class="text-danger small" />
                            </div>
                            <div class="mb-3">
                                <label for="Description" class="form-label">Description</label>
                                <InputTextArea id="Description" class="form-control" @bind-Value="newRepo.Description" />
                                <ValidationMessage For="@(() => newRepo.Description)" class="text-danger small" />
                            </div>
                            <div class="mb-3">
                                <label for="GitignoreTemplate" class="form-label">.gitignore Template</label>
                                <InputSelect id="GitignoreTemplate" class="form-select" @bind-Value="newRepo.selectedGitignore">
                                    <option value="">TODO: Add more stuff</option>
                                    <option value="">TODO: Maybe add checkboxes instead</option>
                                    <option value="">TODO: Add general languages (ones that I use at least)</option>
                                    <option value="">TODO: Add general Editors (ones that I use at least)</option>
                                    <option value="">None</option>
                                    <option value="csharp">C#</option>
                                    <option value="node">Node.js</option>
                                    <option value="dotnet">.NET</option>
                                    <option value="python">Python</option>
                                </InputSelect>
                            </div>

                            <div class="d-flex justify-content-end mt-3">
                                <button class="btn btn-primary">Create</button>
                                <button class="btn btn-outline-secondary ms-2" @onclick="HideModal">Cancel</button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    }
    <div class="card shadow-sm">
        <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
            <span>Repositories</span>
            @* Example future button placeholder *@
            <button class="btn btn-sm btn-primary" @onclick="() => ShowModal()">New</button>
        </div>

        <div class="card-body p-0 overflow-auto" style="max-height: 70vh;">
            <ul class="list-group list-group-flush">
                @foreach (var repo in Model.Repositories)
                {
                    <li class="list-group-item d-flex flex-column gap-1">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">
                                <a class="text-decoration-none "
                                    href="/RepositoryManager/@repo.Owner/@repo.RepositoryName">
                                     @repo.RepositoryName
                                </a>
                            </h6>
                            <small class="text-muted">Updated @repo.EditedAt.ToString("MMM d, yyyy")</small>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(repo.Description))
                        {
                            <p class="mb-1 text-muted">@repo.Description</p>
                        }
                        else
                        {
                            <p class="mb-1 text-muted">&nbsp;</p>
                        }
                    </li>
                }
            </ul>
        </div>
    </div>
}



