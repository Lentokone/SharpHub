@using SharpHub.Models
@using SharpHub.Models.Services
@using System.Security.Claims

@inject AuthenticationStateProvider AuthStateProvider
<div class="container mt-4">
    @if (ModalState)
    {
        <CreateRepositoryModal CloseModal="HideModal" AddingToList="AddToList" />
    }
    <div class="card shadow-sm">
        <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
            <span>Repositories</span>
            <button class="btn btn-sm btn-primary" @onclick="() => ShowModal()">New</button>
        </div>
        @if (!Model.Repositories.Any())
        {
            <div class="text-center p-4">
                <p class="text-muted">No repositories found.</p>
            </div>
        }
        else
        {
            <div class="card-body p-0 overflow-auto" style="max-height: 70vh;">
                <ul class="list-group list-group-flush">
                    @foreach (var repo in Model.Repositories)
                    {
                        <li class="list-group-item d-flex flex-column gap-1">
                            <div class="d-flex justify-content-between align-items-center">
                                <h6 class="mb-0">
                                    <a class="text-decoration-none " href="/RepositoryManager/@repo.Owner/@repo.RepositoryName">
                                        @repo.RepositoryName
                                    </a>
                                </h6>
                                <small class="text-muted">Updated @repo.EditedAt.ToString("MMM d, yyyy")</small>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(repo.Description))
                            {
                                <p class="mb-1 text-muted">@repo.Description</p>
                            }
                            else
                            {
                                <p class="mb-1 text-muted">&nbsp;</p>
                            }
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
</div>


@code {
    [Parameter]
    public required RepositoryListViewModel Model { get; set; }

    private bool ModalState;

    private void ShowModal()
    {
        ModalState = true;
    }
    private void HideModal()
    {
        StateHasChanged();
        ModalState = false;
    }

    private void OnBackdropClick()
    {
        HideModal();
    }

    private void AddToList(Repository NewRepo)
    {
        Model.Repositories.Add(NewRepo);
        Console.WriteLine($"Added: {NewRepo.RepositoryName}, total count: {Model.Repositories.Count}");
        StateHasChanged();
        HideModal();
    }
}

